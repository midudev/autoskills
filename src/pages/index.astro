---
import Layout from "@/layouts/Layout.astro";
import "@/styles/global.css";
import TerminalAnimation from "@/components/terminal-animation.astro";
import Options from "@/sections/options.astro";
import Separator from "@/components/separator.astro";
import CopyButton from "@/components/copy-button.astro";
import HowItWorks from "@/sections/how-it-works.astro";
import Footer from "@/sections/footer.astro";
import SupportedTechnologiesSkills from "@/sections/supported-technologies-skills.astro";

interface Sponsor {
  login: string;
  id: number;
}

const featuredSponsors: Sponsor[] = [
  { login: "crisvegadev", id: 17342446 },
  { login: "pmNiko", id: 18277737 },
  { login: "santiagohernandezs", id: 68081080 },
  { login: "joelguizado", id: 71227026 },
  { login: "SergioAcostaTer", id: 98357160 },
  { login: "Bykhe", id: 141531098 },
  { login: "ChristianUtria", id: 164814299 },
  { login: "x1xhlol", id: 185671340 },
  { login: "Gjusev", id: 71157156 },
  { login: "meogiegieuax", id: 207284467 },
  { login: "sneugoeanxuer", id: 212690065 },
  { login: "cereauaioer", id: 264738581 },
  { login: "architest8", id: 264739452 },
];

let sponsors: Sponsor[] = featuredSponsors;

try {
  const token = import.meta.env.GITHUB_TOKEN;
  if (token) {
    const res = await fetch("https://api.github.com/graphql", {
      method: "POST",
      headers: {
        Authorization: `bearer ${token}`,
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        query: `{
          user(login: "midudev") {
            sponsorshipsAsMaintainer(first: 100, activeOnly: true) {
              nodes {
                sponsorEntity {
                  ... on User { login databaseId }
                  ... on Organization { login databaseId }
                }
              }
            }
          }
        }`,
      }),
    });
    const data = await res.json();
    const live = (data?.data?.user?.sponsorshipsAsMaintainer?.nodes ?? [])
      .map((n: any) => ({
        login: n.sponsorEntity?.login,
        id: n.sponsorEntity?.databaseId,
      }))
      .filter((s: Sponsor) => s.login && s.id);
    if (live.length > 0) sponsors = live;
  }
} catch {
  // Falls back to featuredSponsors
}

const { default: cliPkg } = await import(
  "../../packages/autoskills/package.json",
  { with: { type: "json" } }
);
const cliVersion = cliPkg.version;
---

<Layout>
  <!-- Left column: scrollable content -->
  <main
    class="text-sm leading-relaxed px-6 py-12 lg:w-1/2 lg:pl-12 lg:pr-8 lg:py-16"
  >
    <!-- ASCII Logo (animated reveal) -->
    <pre
      id="ascii-logo"
      class="text-[10px] sm:text-xs lg:text-[9px] leading-none mb-8 h-[6lh] overflow-hidden"
      aria-hidden="true">
    </pre>

    <h1 class="text-zinc-400 mb-8">
      Auto-detect your tech stack and install the best<br />
      AI agent skills for your project.
    </h1>

    <CopyButton />
    <TerminalAnimation cliVersion={cliVersion} />

    <Separator />
    <HowItWorks />

    <Separator />
    <Options />

    <Separator />
    <SupportedTechnologiesSkills />

    <Separator />
    <Footer sponsors={sponsors} />
  </main>

  <script>
    // ‚ĒÄ‚ĒÄ ASCII logo animation ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    {
      const LOGO_LINES = [
        " ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó     ‚Ėą‚Ėą‚ēó     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó",
        "‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ",
        "‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó",
        "‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ     ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ",
        "‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ   ‚Ėą‚Ėą‚ēĎ   ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ",
        "‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ    ‚ēö‚ēź‚ēĚ    ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ",
      ];

      const START_COLOR = "#3f3f46"; // zinc-700 (gris clarito)
      const END_COLOR = "#f4f4f5"; // zinc-100 (blanco)

      const logo = document.getElementById("ascii-logo")!;
      const cols = Math.max(...LOGO_LINES.map((l) => l.length));
      const rows = LOGO_LINES.length;

      // Build grid
      const grid: HTMLSpanElement[][] = [];
      for (const line of LOGO_LINES) {
        const row: HTMLSpanElement[] = [];
        const lineEl = document.createElement("div");
        lineEl.style.height = "1lh";
        for (let c = 0; c < cols; c++) {
          const ch = line[c] ?? " ";
          const span = document.createElement("span");
          span.textContent = ch;
          span.style.color = START_COLOR;
          lineEl.appendChild(span);
          row.push(span);
        }
        logo.appendChild(lineEl);
        grid.push(row);
      }

      // Diagonal sweep: top-left to bottom-right, gray ‚Üí white
      const maxDist = cols + rows;
      const SPEED = 0.9;
      let frame = 0;
      const totalFrames = Math.ceil((maxDist + 10) / SPEED);

      function animate() {
        const waveFront = frame * SPEED;

        for (let r = 0; r < rows; r++) {
          for (let c = 0; c < grid[r].length; c++) {
            const dist = c + r * 3;
            const progress = Math.max(0, Math.min(1, (waveFront - dist) / 10));

            const gray = Math.round(63 + progress * (244 - 63));
            grid[r][c].style.color = `rgb(${gray},${gray},${gray})`;
          }
        }

        frame++;
        if (frame <= totalFrames) {
          requestAnimationFrame(animate);
        } else {
          for (let r = 0; r < rows; r++)
            for (let c = 0; c < grid[r].length; c++)
              grid[r][c].style.color = END_COLOR;
        }
      }

      requestAnimationFrame(animate);
    }
  </script>
</Layout>
