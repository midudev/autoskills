---
import Layout from "@/layouts/Layout.astro";
import "@/styles/global.css";
import TerminalAnimation from "@/components/terminal-animation.astro";
import Options from "@/sections/options.astro";
import Separator from "@/components/separator.astro";
import CopyButton from "@/components/copy-button.astro";
import HowItWorks from "@/sections/how-it-works.astro";
import Footer from "@/sections/footer.astro";

const iconFiles = import.meta.glob<string>("../icons/*.svg", {
  query: "?raw",
  import: "default",
  eager: true,
});

function toFilename(name: string) {
  return (
    name
      .toLowerCase()
      .replace(/\//g, "-")
      .replace(/\s+/g, "-")
      .replace(/\./g, "") + ".svg"
  );
}

function getIcon(name: string): string | undefined {
  const key = `../icons/${toFilename(name)}`;
  return iconFiles[key];
}

interface Sponsor {
  login: string;
  id: number;
}

const featuredSponsors: Sponsor[] = [
  { login: "crisvegadev", id: 17342446 },
  { login: "pmNiko", id: 18277737 },
  { login: "santiagohernandezs", id: 68081080 },
  { login: "joelguizado", id: 71227026 },
  { login: "SergioAcostaTer", id: 98357160 },
  { login: "Bykhe", id: 141531098 },
  { login: "ChristianUtria", id: 164814299 },
  { login: "x1xhlol", id: 185671340 },
  { login: "Gjusev", id: 71157156 },
  { login: "meogiegieuax", id: 207284467 },
  { login: "sneugoeanxuer", id: 212690065 },
  { login: "cereauaioer", id: 264738581 },
  { login: "architest8", id: 264739452 },
];

let sponsors: Sponsor[] = featuredSponsors;

try {
  const token = import.meta.env.GITHUB_TOKEN;
  if (token) {
    const res = await fetch("https://api.github.com/graphql", {
      method: "POST",
      headers: {
        Authorization: `bearer ${token}`,
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        query: `{
          user(login: "midudev") {
            sponsorshipsAsMaintainer(first: 100, activeOnly: true) {
              nodes {
                sponsorEntity {
                  ... on User { login databaseId }
                  ... on Organization { login databaseId }
                }
              }
            }
          }
        }`,
      }),
    });
    const data = await res.json();
    const live = (data?.data?.user?.sponsorshipsAsMaintainer?.nodes ?? [])
      .map((n: any) => ({
        login: n.sponsorEntity?.login,
        id: n.sponsorEntity?.databaseId,
      }))
      .filter((s: Sponsor) => s.login && s.id);
    if (live.length > 0) sponsors = live;
  }
} catch {
  // Falls back to featuredSponsors
}

const { SKILLS_MAP } = await import("../../packages/autoskills/skills-map.ts");
const { default: cliPkg } = await import(
  "../../packages/autoskills/package.json",
  { with: { type: "json" } }
);
const cliVersion = cliPkg.version;

const popularityOrder = [
  "typescript",
  "zod",
  "react-hook-form",
  "react",
  "nextjs",
  "node",
  "tailwind",
  "vue",
  "angular",
  "vite",
  "astro",
  "nuxt",
  "svelte",
  "expo",
  "react-native",
  "bun",
  "deno",
  "supabase",
  "cloudflare",
  "cloudflare-agents",
  "cloudflare-durable-objects",
  "cloudflare-ai",
  "terraform",
  "vercel-deploy",
  "vercel-ai",
  "shadcn",
  "playwright",
  "turborepo",
  "better-auth",
  "clerk",
  "pinia",
  "neon",
  "remotion",
  "gsap",
  "oxlint",
  "express",
  "go",
  "swiftui",
  "azure",
  "aws",
  "elevenlabs",
  "kotlin-multiplatform",
  "android",
  "java",
  "springboot",
  "threejs",
];

const skillsMap = [...SKILLS_MAP].sort((a: any, b: any) => {
  const ai = popularityOrder.indexOf(a.id);
  const bi = popularityOrder.indexOf(b.id);
  return (ai === -1 ? Infinity : ai) - (bi === -1 ? Infinity : bi);
});
---

<Layout>
  <!-- Left column: scrollable content -->
  <main
    class="text-sm leading-relaxed px-6 py-12 lg:w-1/2 lg:pl-12 lg:pr-8 lg:py-16"
  >
    <!-- ASCII Logo (animated reveal) -->
    <pre
      id="ascii-logo"
      class="text-[10px] sm:text-xs lg:text-[9px] leading-none mb-8 h-[6lh] overflow-hidden"
      aria-hidden="true">
    </pre>

    <h1 class="text-zinc-400 mb-8">
      Auto-detect your tech stack and install the best<br />
      AI agent skills for your project.
    </h1>

    <CopyButton />

    <TerminalAnimation cliVersion={cliVersion} />

    <!-- Separator -->
    <Separator />

    <HowItWorks />

    <!-- Separator -->
    <Separator />

    <Options />

    <!-- Separator -->
    <Separator />

    <!-- Supported Technologies & Skills -->
    <div class="mb-12">
      <p class="text-zinc-600 mb-2 uppercase tracking-widest text-xs">
        Supported technologies & skills
      </p>
      <p class="text-zinc-600 mb-6">
        Each technology auto-installs these skills from <a
          href="https://skills.sh"
          target="_blank"
          rel="noopener"
          class="text-zinc-400 underline underline-offset-2 decoration-zinc-700 hover:decoration-zinc-400 transition-colors"
          >skills.sh</a
        >.
      </p>
      <div class="space-y-0">
        {
          skillsMap.map((tech) => (
            <div class="group border-b border-zinc-800/40 py-2.5 first:border-t">
              <div class="flex items-start gap-3">
                <div class="flex items-center gap-2 w-32 shrink-0 pt-px">
                  {getIcon(tech.name) ? (
                    <span
                      class={`w-3.5 h-3.5 shrink-0 opacity-50 group-hover:opacity-100 transition-opacity [&>svg]:w-full [&>svg]:h-full`}
                      set:html={getIcon(tech.name)}
                    />
                  ) : (
                    <span class="w-3.5 h-3.5 shrink-0" />
                  )}
                  <span class="text-zinc-300 group-hover:text-zinc-100 transition-colors text-xs">
                    {tech.name}
                  </span>
                </div>
                <div class="flex-1 min-w-0">
                  {tech.skills.length > 0 ? (
                    <div class="flex flex-wrap gap-x-3 gap-y-0.5">
                      {tech.skills.map((skill) => (
                        <a
                          href={
                            skill.startsWith("http")
                              ? skill
                              : `https://skills.sh/${skill}`
                          }
                          target="_blank"
                          rel="noopener"
                          class="text-xs text-zinc-600 hover:text-cyan-400 transition-colors"
                        >
                          {skill.startsWith("http")
                            ? new URL(skill).hostname + new URL(skill).pathname
                            : skill.split("/").slice(2).join("/")}
                        </a>
                      ))}
                    </div>
                  ) : (
                    <span class="text-xs text-zinc-700 italic">
                      no skills yet
                    </span>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Separator -->
    <Separator />
    <Footer sponsors={sponsors} />
  </main>

  <script>
    // в”Ђв”Ђ ASCII logo animation в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    {
      const LOGO_LINES = [
        " в–€в–€в–€в–€в–€в•— в–€в–€в•—   в–€в–€в•—в–€в–€в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в•—  в–€в–€в•—в–€в–€в•—в–€в–€в•—     в–€в–€в•—     в–€в–€в–€в–€в–€в–€в–€в•—",
        "в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•‘   в–€в–€в•‘в•љв•ђв•ђв–€в–€в•”в•ђв•ђв•ќв–€в–€в•”в•ђв•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв•ђв•ђв•ќв–€в–€в•‘ в–€в–€в•”в•ќв–€в–€в•‘в–€в–€в•‘     в–€в–€в•‘     в–€в–€в•”в•ђв•ђв•ђв•ђв•ќ",
        "в–€в–€в–€в–€в–€в–€в–€в•‘в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в–€в–€в–€в•”в•ќ в–€в–€в•‘в–€в–€в•‘     в–€в–€в•‘     в–€в–€в–€в–€в–€в–€в–€в•—",
        "в–€в–€в•”в•ђв•ђв–€в–€в•‘в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘в•љв•ђв•ђв•ђв•ђв–€в–€в•‘в–€в–€в•”в•ђв–€в–€в•— в–€в–€в•‘в–€в–€в•‘     в–€в–€в•‘     в•љв•ђв•ђв•ђв•ђв–€в–€в•‘",
        "в–€в–€в•‘  в–€в–€в•‘в•љв–€в–€в–€в–€в–€в–€в•”в•ќ   в–€в–€в•‘   в•љв–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в–€в–€в–€в–€в–€в•‘в–€в–€в•‘  в–€в–€в•—в–€в–€в•‘в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в–€в–€в–€в–€в–€в•‘",
        "в•љв•ђв•ќ  в•љв•ђв•ќ в•љв•ђв•ђв•ђв•ђв•ђв•ќ    в•љв•ђв•ќ    в•љв•ђв•ђв•ђв•ђв•ђв•ќ в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќв•љв•ђв•ќ  в•љв•ђв•ќв•љв•ђв•ќв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќ",
      ];

      const START_COLOR = "#3f3f46"; // zinc-700 (gris clarito)
      const END_COLOR = "#f4f4f5"; // zinc-100 (blanco)

      const logo = document.getElementById("ascii-logo")!;
      const cols = Math.max(...LOGO_LINES.map((l) => l.length));
      const rows = LOGO_LINES.length;

      // Build grid
      const grid: HTMLSpanElement[][] = [];
      for (const line of LOGO_LINES) {
        const row: HTMLSpanElement[] = [];
        const lineEl = document.createElement("div");
        lineEl.style.height = "1lh";
        for (let c = 0; c < cols; c++) {
          const ch = line[c] ?? " ";
          const span = document.createElement("span");
          span.textContent = ch;
          span.style.color = START_COLOR;
          lineEl.appendChild(span);
          row.push(span);
        }
        logo.appendChild(lineEl);
        grid.push(row);
      }

      // Diagonal sweep: top-left to bottom-right, gray в†’ white
      const maxDist = cols + rows;
      const SPEED = 0.9;
      let frame = 0;
      const totalFrames = Math.ceil((maxDist + 10) / SPEED);

      function animate() {
        const waveFront = frame * SPEED;

        for (let r = 0; r < rows; r++) {
          for (let c = 0; c < grid[r].length; c++) {
            const dist = c + r * 3;
            const progress = Math.max(0, Math.min(1, (waveFront - dist) / 10));

            const gray = Math.round(63 + progress * (244 - 63));
            grid[r][c].style.color = `rgb(${gray},${gray},${gray})`;
          }
        }

        frame++;
        if (frame <= totalFrames) {
          requestAnimationFrame(animate);
        } else {
          for (let r = 0; r < rows; r++)
            for (let c = 0; c < grid[r].length; c++)
              grid[r][c].style.color = END_COLOR;
        }
      }

      requestAnimationFrame(animate);
    }
  </script>
</Layout>
