---
import SkillList from "@/components/skill-list.astro";
import TechList from "@/components/tech-list.astro";

const { getSkillsMap } = await import("@/utils/get-skills-map.ts");
const { skillsMap } = await getSkillsMap();
---

<!-- Supported Technologies & Skills -->
<div class="mb-12">
  <p class="text-zinc-600 mb-2 uppercase tracking-widest text-xs">
    Supported technologies & skills
  </p>
  <p class="text-zinc-600 mb-6">
    Each technology auto-installs these skills from <a
      href="https://skills.sh"
      target="_blank"
      rel="noopener"
      class="text-zinc-400 underline underline-offset-2 decoration-zinc-700 hover:decoration-zinc-400 transition-colors"
      >skills.sh</a
    >.
  </p>
  <div class="space-y-0">
    {
      skillsMap.map((tech) => (
        <div class="group border-b border-zinc-800/40 py-2.5 first:border-t">
          <div class="flex items-start gap-3">
            <TechList name={tech.name} />
            <SkillList skills={tech.skills} />
          </div>
        </div>
      ))
    }
  </div>
</div>
