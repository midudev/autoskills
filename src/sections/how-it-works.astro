---
import Step from "@/components/ui/step.astro";

const steps = [
  {
    number: 1,
    title: "Run the command",
    description:
      "Execute <span class='text-zinc-400'>npx autoskills</span> in your project root.",
  },
  {
    number: 2,
    title: "Auto-detect",
    description:
      "Scans your package.json and config files to detect your stack.",
  },
  {
    number: 3,
    title: "Install skills",
    description:
      "The best AI agent skills are installed automatically via <span class='text-zinc-400'>skills.sh</span>.",
  },
];
---

<div class="mb-12">
  <p class="text-zinc-600 mb-6 uppercase tracking-widest text-xs">
    How it works
  </p>
  <div class="space-y-4">
    {
      steps.map((step) => (
        <Step
          number={step.number}
          title={step.title}
          description={step.description}
        />
      ))
    }
  </div>
</div>
